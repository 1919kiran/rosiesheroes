---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Home | Rosie's Heroes",
  description = "We reduce suffering at scale and create safer communities through spay/neuter and on-the-ground care for Indian street dogs."
} = Astro.props;

import '../styles/fonts.css';
import '../styles/tokens.css';
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🐾</text></svg>" />
</head>
<body>
  <slot />
  <script src="/scripts/main.js" is:inline></script>
</body>
</html>
