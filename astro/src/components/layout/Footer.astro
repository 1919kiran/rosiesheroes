  <!-- Watermark text -->
  <div class="footer-watermark" aria-hidden="true">Rosie's<br/>Heroes</div>

  <div class="footer-inner">

    <!-- Dogs group illustration -->
    <div class="footer-illus">
      <img
        src="/images/logo-dogs.png"
        alt="Group of dogs illustration"
        width="210"
        height="140"
        loading="lazy"
      />
    </div>

    <!-- Tagline -->
    <p class="footer-tagline">
      Transforming communities through sustained welfare for street dogs.
    </p>

    <!-- Footer navigation links — 4 columns -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <ul class="footer-nav-col" role="list">
        <li><a href="#vision"            class="footer-link">Vision</a></li>
        <li><a href="#rosies-story"      class="footer-link">Rosie's Story</a></li>
        <li><a href="#roadmap"           class="footer-link">Roadmap</a></li>
        <li><a href="#impact-multiplier" class="footer-link">Impact Multiplier</a></li>
      </ul>
      <ul class="footer-nav-col" role="list">
        <li><a href="#adopt"     class="footer-link">Adopt</a></li>
        <li><a href="#volunteer" class="footer-link">Volunteer</a></li>
        <li><a href="#donate"    class="footer-link">Donate</a></li>
        <li><a href="#partner"   class="footer-link">Partner</a></li>
      </ul>
      <ul class="footer-nav-col" role="list">
        <li><a href="#rosies-story" class="footer-link">Happy Tails</a></li>
      </ul>
      <ul class="footer-nav-col" role="list">
        <li><a href="#contact"      class="footer-link">Contact Us</a></li>
      </ul>
    </nav>

    <!-- Copyright -->
    <div class="footer-legal">
      <p>&copy; 2026 Rosie's Heroes. All rights reserved.</p>
      <p>A 501c3 animal rescue dedicated to reducing suffering at scale for dogs and people.</p>
      <p>Tax number 38-4382498</p>
    </div>

  </div>
</footer>

<style>
  /* ============================================================
     FOOTER — component-scoped styles
     ============================================================ */

  #site-footer {
    position: relative;
    background-color: var(--color-dark-brown);
    color: var(--color-text-on-dark);
    overflow: hidden;
    padding: 56px 0 40px;
  }

  /* ---- WATERMARK TEXT ---- */
  .footer-watermark {
    position: absolute;
    top: 35%;
    left: 40px;
    transform: translateY(-50%);
    font-family: var(--font-heading);
    font-size: 72px;
    font-weight: 600;
    line-height: 1.1;
    color: rgba(255, 239, 218, 0.18);
    pointer-events: none;
    z-index: 0;
  }

  /* ---- DECORATIVE PAWS ---- */
  .footer-paw {
    position: absolute;
    color: #6B4A35;
    opacity: 0.50;
    pointer-events: none;
  }

  .footer-paw--left {
    width: 200px;
    height: 200px;
    bottom: 20px;
    left: -20px;
    transform: rotate(-15deg);
  }

  .footer-paw--right {
    width: 220px;
    height: 220px;
    top: 20px;
    right: -30px;
    transform: rotate(20deg);
  }

  /* ---- INNER CONTAINER ---- */
  .footer-inner {
    position: relative;
    max-width: var(--site-width);
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    z-index: 1;
  }

  /* ---- ILLUSTRATION ---- */
  .footer-illus {
    margin-bottom: 20px;
  }

  .footer-illus img {
    display: block;
    width: auto;
    max-width: 210px;
    height: auto;
  }

  /* ---- TAGLINE ---- */
  .footer-tagline {
    font-family: var(--font-heading);
    font-size: var(--text-lg); /* 18px */
    font-weight: 600;
    color: var(--color-text-warm); /* #FFEFDA */
    text-align: center;
    margin-bottom: 32px;
    line-height: var(--lh-snug);
    max-width: 520px;
  }

  /* ---- FOOTER NAV ---- */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 48px;
    margin-bottom: 40px;
    align-items: flex-start;
    justify-content: center;
  }

  .footer-nav-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-link {
    font-family: var(--font-heading);
    font-size: var(--text-sm); /* 15px */
    font-weight: 500;
    color: var(--color-text-on-dark);
    text-decoration: none;
    opacity: 0.85;
    white-space: nowrap;
    transition: opacity 0.2s ease, color 0.2s ease;
  }

  .footer-link:hover {
    opacity: 1;
    color: var(--color-gold);
  }

  /* ---- LEGAL ---- */
  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: 4px;
    text-align: center;
  }

  .footer-legal p {
    font-family: var(--font-heading);
    font-size: var(--text-xs); /* 14px */
    color: var(--color-text-on-dark);
    opacity: 0.6;
    line-height: var(--lh-relaxed);
    margin: 0;
  }
</style>
