  <!-- Dog + tennis ball illustrations -->
  <img
    id="vision-tennis-ball"
    src="/images/ball-tennis.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
  />
  <img
    id="vision-labrador"
    src="/images/illus-labrador-running.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
  />

</section>

<style>
  #vision {
    background-color: var(--color-cream-vision);
    padding: var(--space-8) 0 var(--space-10);
    position: relative;
    overflow: visible;
  }

  .vision-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* ---- Section heading — centered ---- */
  .vision-label {
    font-family: var(--font-heading);
    font-size: var(--text-section); /* 38px */
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: var(--ls-snug);
    line-height: var(--lh-tight);
    text-align: center;
  }

  /* ---- Body paragraph ---- */
  .vision-body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--lh-relaxed);
    margin: 0;
  }

  /* ---- Airplane parallax ----
     Positioned at bottom of section; JS will animate transform.
     Starts off-screen right; uses section-relative t in main.js.  */
  #airplane {
    position: absolute;
    left: calc(50% + 390px);
    bottom: 180px;
    width: 209px;
    height: 127px;
    pointer-events: none;
    will-change: transform;
    z-index: 2;
    opacity: 0; /* hidden by default; JS controls opacity */
  }

  /* ---- Decorative paw prints ---- */
  .paw-decor {
    position: absolute;
    color: #E8C278;
    opacity: 0.28;
    pointer-events: none;
  }

  /* Top-left cluster */
  .paw-decor--tl {
    width: 80px;
    height: 80px;
    top: 80px;
    left: 28px;
  }

  /* Bottom-left cluster */
  .paw-decor--bl {
    width: 65px;
    height: 65px;
    bottom: 100px;
    left: 50px;
    opacity: 0.22;
  }

  /* Bottom-right */
  .paw-decor--br {
    width: 70px;
    height: 70px;
    bottom: 200px;
    right: 40px;
    opacity: 0.22;
  }

  /* ---- Labrador + tennis ball illustrations ---- */
  #vision-labrador {
    position: absolute;
    bottom: -20px;
    left: 40px;
    width: 160px;
    height: auto;
    pointer-events: none;
    z-index: 2;
  }

  #vision-tennis-ball {
    position: absolute;
    bottom: 5px;
    left: 20px;
    width: 40px;
    height: auto;
    pointer-events: none;
    z-index: 3;
  }

  @media (max-width: 900px) {
    #vision-labrador,
    #vision-tennis-ball,
    #airplane {
      display: none;
    }
  }
</style>
